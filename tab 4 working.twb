      <aliases enabled='yes' />
      <column caption='Clean Category' datatype='string' name='[Calculation_273875169510133760]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER(TRIM([Category])), &quot;beverage&quot;) THEN &quot;Beverages&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;household&quot;) THEN &quot;Household&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;personal&quot;) THEN &quot;Personal Care&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;premium&quot;) THEN &quot;Premium&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;staple&quot;) THEN &quot;Staples&quot;&#13;&#10;&#13;&#10;ELSE TRIM([Category])&#13;&#10;END' />
      </column>
      <column caption='Clean State' datatype='string' name='[Calculation_273875169514737665]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER(TRIM([State])), &quot;abuja&quot;) OR LOWER(TRIM([State])) = &quot;fct&quot; THEN &quot;Abuja&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;kano&quot;) THEN &quot;Kano&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;lagos&quot;) THEN &quot;Lagos&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;ibadan&quot;) THEN &quot;Ibadan&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;warri&quot;) THEN &quot;Warri&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;port harcourt&quot;) THEN &quot;Port Harcourt&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;aba&quot;) THEN &quot;Aba&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;enugu&quot;) THEN &quot;Enugu&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;kaduna&quot;) THEN &quot;Kaduna&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;onitsha&quot;) THEN &quot;Onitsha&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([State])), &quot;unknown&quot;) THEN &quot;Unknown&quot;&#13;&#10;&#13;&#10;ELSE TRIM([State])&#13;&#10;END' />
      </column>
      <column caption='Gross Margin %' datatype='real' name='[Calculation_779404226909200390]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Gross_Profit_NGN]) / SUM([Revenue_NGN])' />
      </column>
      <column caption='MOM Revenue Change' datatype='real' name='[Calculation_779404226909466631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL(LOOKUP(SUM([Revenue_NGN]),-1)) THEN 0 &#13;&#10;ELSE(SUM([Revenue_NGN])- LOOKUP(SUM([Revenue_NGN]),-1))&#13;&#10;/ ABS(LOOKUP(SUM([Revenue_NGN]),-1)) END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Unit Price' datatype='real' name='[Calculation_779404226910924809]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue_NGN]) / SUM([Quantity_Sold])' />
      </column>
      <column caption='Base Price' datatype='real' name='[Calculation_779404226911133706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF MONTH([Date]) = 1&#13;&#10;AND YEAR([Date]) = 2023&#13;&#10;         THEN [Revenue_NGN] END)&#13;&#10;        / SUM(IF MONTH([Date]) = 1&#13;&#10;AND YEAR([Date]) = 2023&#13;&#10;    THEN [Quantity_Sold]END)  }' />
      </column>
      <column caption='Price Index' datatype='real' name='[Calculation_779404226912231435]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Revenue_NGN]) / SUM([Quantity_Sold]))&#13;&#10;/ MIN([Calculation_779404226911133706]) * 100' />
      </column>
      <column caption='Revenue Contribution' datatype='real' name='[Calculation_779404226915434508]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue_NGN])/ TOTAL(SUM([Revenue_NGN]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal' />
      <column datatype='date' name='[Date]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
        <calculation class='tableau' formula='1' />
      </column>
      <column datatype='integer' name='[Quantity_Sold]' role='measure' type='quantitative' />
      <column datatype='real' name='[Revenue_NGN]' role='measure' type='quantitative' />
      <column aggregation='None' datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
