              <calculation class='tableau' formula='IF CONTAINS(LOWER(TRIM([Category])), &quot;beverage&quot;) THEN &quot;Beverages&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;household&quot;) THEN &quot;Household&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;personal&quot;) THEN &quot;Personal Care&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;premium&quot;) THEN &quot;Premium&quot;&#13;&#10;&#13;&#10;ELSEIF CONTAINS(LOWER(TRIM([Category])), &quot;staple&quot;) THEN &quot;Staples&quot;&#13;&#10;&#13;&#10;ELSE TRIM([Category])&#13;&#10;END' />
